# 本地裸跑后端时连本地 docker-compose 起的容器(宿主端口已避开本机已有 MySQL/Redis)
DB_HOST=localhost
DB_PORT=3307
DB_USER=airportbus
DB_PASSWORD=airportbus
REDIS_HOST=localhost
REDIS_PORT=6380
SEED_ENABLED=true

# 真实 SMTP(可选)。填上后 docker compose 的 app 会真发验证码邮件;留空则后端走 ConsoleMailer,
# 验证码打印到 `docker compose logs app`(==== DEV MAIL ====)。务必把真实授权码写进 .env(已被 gitignore),不要写进本模板。
# MAIL_HOST=smtp.qq.com
# MAIL_PORT=465
# MAIL_USERNAME=you@qq.com
# MAIL_PASSWORD=your-smtp-auth-code
# MAIL_FROM=you@qq.com   # 必须 = 认证邮箱,否则 QQ 拒发
