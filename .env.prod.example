# 生产环境变量模板。复制为 .env.prod 并填入真实值(.env.prod 已被 .gitignore,不会进仓库):
#   cp .env.prod.example .env.prod && vi .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# 数据库(强密码;DB_PASSWORD 同时用于 MySQL 的 airportbus 用户和后端连接)
MYSQL_ROOT_PASSWORD=改成强随机串
DB_PASSWORD=改成强随机串

# 种子管理员(首启幂等创建;务必改掉默认 admin12345)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=改成强随机串

# 真实 SMTP(可选)。留空则注册验证码/找回链接打印到 `docker compose logs app`(==== DEV MAIL ====)
# MAIL_HOST=smtp.qq.com
# MAIL_PORT=465
# MAIL_USERNAME=you@qq.com
# MAIL_PASSWORD=你的SMTP授权码
# MAIL_FROM=you@qq.com   # 必须 = 认证邮箱,否则 QQ 等会拒发
